# ── 必填：JWT 簽章金鑰 ─────────────────────────────────────────────────
# 至少 32 字元；後端啟動時會驗證，太短會直接 raise ValueError。
# 產生強隨機 key：
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
SECRET_KEY=

# ── LLM Provider（選填，僅 /sync/upload-html fallback path 用到）──────────
# 預設 API 直連模式 (/sync/upload-structured) 不會呼叫 LLM。
LLM_PROVIDER=claude

# Anthropic API Key (LLM_PROVIDER=claude 時使用)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Ollama 設定 (LLM_PROVIDER=ollama 時使用，符合地端資安部署)
# - Docker 環境用 host.docker.internal（Mac/Windows 內建，Linux 用 docker-compose extra_hosts）
# - 本機直跑（不走 Docker）改成 http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
# 推薦模型：
#   qwen2.5vl:7b   ← 預設（vision + 中文 + JSON 輸出俱佳，~5GB）
#   qwen3:8b       ← 純文字、最強 reasoning（不能跑 vision fallback）
#   llama3.2-vision:11b  ← 替代方案
OLLAMA_MODEL=qwen2.5vl:7b

# ── 安全 ──────────────────────────────────────────────────────────────
# API Key 保護 /sync/upload-structured 與 /sync/upload-html。
# 留空 = 無認證（POC / 本機開發）。正式部署務必設一個隨機強密碼。
# Chrome Extension 須在 headers 帶 X-Sync-API-Key: <值>。
SYNC_API_KEY=

# CORS：除了預設的 localhost dev 端點，可額外加入的允許來源
# 逗號分隔，例：ALLOW_CORS_ORIGINS=https://your-smart-app.example.com,https://dashboard.example.com
ALLOW_CORS_ORIGINS=

# ── FHIR ──────────────────────────────────────────────────────────────
# 對外公開的 FHIR base URL（SMART CapabilityStatement 會用到）
FHIR_BASE_URL=http://localhost:8010/fhir
