{
  "name": "nhi-fhir-bridge",
  "version": "0.20.10",
  "private": true,
  "description": "NHI 健康存摺 → FHIR R4 bridge with extension, backend, and dashboard.",
  "workspaces": [
    "packages/*",
    "backend-ts",
    "extension"
  ],
  "scripts": {
    "build:extension": "npm run build --workspace extension",
    "test": "npm run test:backend && npm run test:extension",
    "test:backend": "npm run test --workspace backend-ts",
    "test:extension": "npm run test --workspace extension",
    "test:coverage": "npm run test:coverage --workspace extension",
    "verify-sync": "node scripts/verify-sync.mjs"
  }
}