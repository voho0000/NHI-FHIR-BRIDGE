# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# Chrome extension build output is intentionally committed so
# non-developers can load `extension/dist/` straight after `git clone`
# (no build step required). Re-run `npm run build:extension` before
# each commit that touches `extension/src/` or `packages/mapper/`.
!extension/dist/

# Env
.env
.env.local

# Data (SQLite DB)
data/
**/data/*.db
**/data/*.db-shm
**/data/*.db-wal

# HTML captured from real HIS — contains PHI, never commit
dev-replay/
**/dev-replay/
*.html.captured

# Node
node_modules/
.next/
frontend/.next/
*.tsbuildinfo

# IDE
.vscode/
.idea/
*.swp

# Claude Code local settings (per-clone, not shared)
.claude/
# CLAUDE.md is local-only project memory for Claude Code (internal agent notes,
# incident details, live-probe narratives) — not part of the public repo.
# Contributor-facing engineering rules live in DEVELOPMENT_RULES.md instead.
CLAUDE.md

# OS
.DS_Store
Thumbs.db

# Playwright
/test-results/
/playwright-report/

# Vitest v8 coverage HTML report — regenerate locally with
# `npm run test:coverage`; CI shouldn't push to the repo.
**/coverage/

# Logs
*.log

# Local-only files (audit notes etc.) — never commit
*.local.md
