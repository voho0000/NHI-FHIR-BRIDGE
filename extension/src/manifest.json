{
  "manifest_version": 3,
  "name": "健康懷爾抓抓 NHI-FHIR-BRIDGE",
  "version": "1.1.0",
  "description": "將健保署「健康存摺」就醫、用藥、檢驗紀錄轉換為 FHIR R4 格式。資料不會傳送給開發者；預設只在本機處理。",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "健康懷爾抓抓 NHI-FHIR-BRIDGE",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "storage", "scripting", "downloads", "alarms", "unlimitedStorage"],
  "host_permissions": ["https://myhealthbank.nhi.gov.tw/*"],
  "optional_host_permissions": ["http://localhost/*", "http://127.0.0.1/*"]
}
