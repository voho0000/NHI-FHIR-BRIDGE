{
  "manifest_version": 3,
  "name": "NHI-FHIR Bridge Capture",
  "version": "0.8.5",
  "description": "將健保署健康存摺頁面擷取並轉換為 FHIR R4，透過 NHI-FHIR-Bridge 後端服務。",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "NHI-FHIR Bridge",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "downloads",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://myhealthbank.nhi.gov.tw/*"
  ]
}